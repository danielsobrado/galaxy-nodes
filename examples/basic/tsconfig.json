{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "baseUrl": ".",
    "ignoreDeprecations": "6.0",
    "noEmit": true,
    "paths": {
      "galaxy-nodes": ["../../src/adapters/index.ts"],
      "galaxy-nodes/presets/initiatives": ["../shared/presets/initiatives.tsx"],
      "galaxy-nodes/presets/codegraph": ["../shared/presets/codegraph.tsx"],
      "galaxy-nodes/styles.css": ["../../src/styles.css"]
