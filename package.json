{
  "name": "galaxy-nodes",
  "description": "Reusable React + Three.js library for interactive galaxy-like graph visualizations.",
  "version": "0.1.0",
  "private": false,
  "license": "MIT",
  "author": "Daniel Sobrado",
  "homepage": "https://github.com/danielsobrado/galaxy-nodes#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/danielsobrado/galaxy-nodes.git"
  },
  "bugs": {
    "url": "https://github.com/danielsobrado/galaxy-nodes/issues"
  },
  "keywords": [
    "react",
    "threejs",
    "graph",
    "visualization",
    "typescript",
    "webgl"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./core": {
      "types": "./dist/core.d.ts",
      "import": "./dist/core.js",
      "require": "./dist/core.cjs"
    },
    "./react": {
      "types": "./dist/react.d.ts",
      "import": "./dist/react.js",
      "require": "./dist/react.cjs"
    },
    "./vue": {
      "types": "./dist/vue.d.ts",
      "import": "./dist/vue.js",
      "require": "./dist/vue.cjs"
    },
    "./angular": {
      "types": "./dist/angular.d.ts",
      "import": "./dist/angular.js",
      "require": "./dist/angular.cjs"
    },
    "./presets/markets": {
      "types": "./dist/presets/markets.d.ts",
      "import": "./dist/presets/markets.js",
      "require": "./dist/presets/markets.cjs"
    },
    "./presets/markets/core": {
      "types": "./dist/presets/markets-core.d.ts",
      "import": "./dist/presets/markets/core.js",
      "require": "./dist/presets/markets/core.cjs"
    },
    "./styles.css": "./dist/styles.css"
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "docs/images/demo1_v0.1.jpg",
    "LICENSE"
  ],
  "sideEffects": [
    "./dist/styles.css",
    "*.css"
  ],
  "scripts": {
    "build": "npm run build:lib",
    "build:example": "tsc --noEmit -p examples/basic/tsconfig.json && vite build --config examples/basic/vite.config.ts",
    "build:lib": "vite build && tsc -p tsconfig.build.json && node scripts/copy-styles.mjs",
    "ci": "npm run lint && npm run format:check && npm test && npm run build && npm run build:example && npm run docs:api",
    "dev": "vite --config examples/basic/vite.config.ts --host 127.0.0.1",
    "docs:api": "typedoc",
    "docs:site": "node scripts/build-pages-site.mjs",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint .",
    "pack:dry": "npm pack --dry-run",
    "prepublishOnly": "npm run build",
    "preview": "vite preview --config examples/basic/vite.config.ts --host 127.0.0.1",
    "test": "vitest run"
  },
  "dependencies": {
    "lucide-react": "1.17.0"
  },
  "peerDependencies": {
    "react": ">=18.2.0 <20",
    "react-dom": ">=18.2.0 <20",
    "three": ">=0.160.0 <1"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "react-dom": {
      "optional": true
    }
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "25.9.1",
    "@types/react": "19.2.15",
    "@types/react-dom": "19.2.3",
    "@types/three": "0.184.1",
    "@vitejs/plugin-react": "6.0.2",
    "eslint": "^10.4.1",
    "globals": "^17.6.0",
    "jsdom": "^29.1.1",
    "prettier": "^3.8.3",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "three": "0.184.0",
    "typedoc": "^0.28.19",
    "typescript": "6.0.3",
    "typescript-eslint": "^8.60.0",
    "vite": "8.0.14",
    "vitest": "3.2.4"
  }
}
