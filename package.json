{
  "name": "galaxy-nodes",
  "description": "Reusable React + Three.js library for interactive galaxy-like graph visualizations.",
  "version": "0.1.0",
  "private": false,
  "license": "MIT",
  "author": "Daniel Sobrado",
  "homepage": "https://github.com/danielsobrado/galaxy-nodes#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/danielsobrado/galaxy-nodes.git"
  },
  "bugs": {
    "url": "https://github.com/danielsobrado/galaxy-nodes/issues"
  },
  "keywords": [
    "react",
    "threejs",
    "graph",
    "visualization",
    "typescript",
    "webgl"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./presets/markets": {
      "types": "./dist/presets/markets.d.ts",
      "import": "./dist/presets/markets.js",
      "require": "./dist/presets/markets.cjs"
    },
    "./styles.css": "./dist/styles.css"
  },
  "files": [
    "dist",
    "README.md",
    "docs/images/demo1_v0.1.jpg",
    "LICENSE"
  ],
  "sideEffects": [
    "./dist/styles.css",
    "*.css"
  ],
  "scripts": {
    "build": "npm run build:lib",
    "build:example": "tsc --noEmit -p examples/basic/tsconfig.json && vite build --config examples/basic/vite.config.ts",
    "build:lib": "vite build && tsc -p tsconfig.build.json && node scripts/copy-styles.mjs",
    "dev": "vite --config examples/basic/vite.config.ts --host 127.0.0.1",
    "pack:dry": "npm pack --dry-run",
    "prepublishOnly": "npm run build",
    "preview": "vite preview --config examples/basic/vite.config.ts --host 127.0.0.1",
    "test": "vitest run"
  },
  "dependencies": {
    "lucide-react": "1.17.0"
  },
  "peerDependencies": {
    "react": ">=18.2.0 <20",
    "react-dom": ">=18.2.0 <20",
    "three": ">=0.160.0 <1"
  },
  "devDependencies": {
    "@types/node": "25.9.1",
    "@types/react": "19.2.15",
    "@types/react-dom": "19.2.3",
    "@types/three": "0.184.1",
    "@vitejs/plugin-react": "6.0.2",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "three": "0.184.0",
    "typescript": "6.0.3",
    "vite": "8.0.14",
    "vitest": "3.2.4"
  }
}
